// Concierge — knowledge-grounded, AI-drafted, human-confirmed service platform.
// Multi-tenant with strict row-level isolation. Every row carries tenantId.
// Runs in its own `concierge` schema on the shared birdseye Postgres, with pgvector.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // transaction pooler (6543) — resilient app runtime
  directUrl = env("DIRECT_URL") // session pooler (5432) — migrations/db push
  schemas   = ["concierge"]
}

/// A brand instance: its settings, voice, and mailbox/channel connections.
model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique // "rheos", "stingray"
  name      String
  voiceGuide String? @db.Text // brand voice rules the drafts follow
  createdAt DateTime @default(now())

  channels        Channel[]
  knowledge       KnowledgeItem[]
  customers       Customer[]
  tickets         Ticket[]
  rules           Rule[]
  users           User[]
  auditEvents     AuditEvent[]
  learningSignals LearningSignal[]
  salesSources    SalesSource[]
  contextNotes    ContextNote[]
  armInventory    ArmInventory[]

  @@schema("concierge")
}

/// A connected intake source: a mailbox (gmail|graph), a social account, a form.
model Channel {
  id             String  @id @default(cuid())
  tenantId       String
  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider       String  // "gmail" | "graph" | "instagram" | "web"
  supportAddress String  // hello@rheosgear.com, support@stingrayboats.com
  businessLine   String  @default("d2c") // "d2c" | "b2b" — splits reporting by business (wholesale@ = b2b)
  cursor         String? // Gmail historyId / Graph deltaLink for incremental sync
  watchExpiresAt DateTime?
  active         Boolean @default(true)

  tickets Ticket[]

  @@unique([tenantId, provider, supportAddress])
  @@index([tenantId])
  @@schema("concierge")
}

/// An FAQ entry, reply script, policy, or product reference — with its index metadata.
model KnowledgeItem {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind          String   // "faq" | "script" | "policy" | "product" | "voice"
  title         String
  answer        String   @db.Text // canonical, approved answer
  triggerPhrases String[] // recognized-intent variations (fast path)
  tags          String[]
  category      String?
  conditions    String?  @db.Text // applicable conditions
  status        String   @default("draft") // "draft" | "approved"
  version       Int      @default(1)
  ownerId       String?
  sourceRef     String?  // provenance: hubspot ticket id, crawled url, doc name
  embedding     Unsupported("extensions.vector(1024)")? // semantic index (Voyage AI, 1024-dim)
  // --- learning + anti-bloat metadata ---
  avoidNotes    String[] // short phrasings reps flagged as do-not-use (a sentence, not a doc)
  exemplar      Boolean  @default(false) // curated gold example for few-shot tone (capped per category)
  timesCited    Int      @default(0) // usage stat — drives decay + consolidation
  lastCitedAt   DateTime? // last time retrieved into a draft (archive if it goes cold)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  citedBy DraftCitation[]

  @@index([tenantId, status])
  @@index([tenantId, category])
  @@index([tenantId, exemplar])
  @@schema("concierge")
}

/// The consolidation detector's output: a proposed change to the Brain, mined from
/// the Ledger (recurring edits/steers, coverage gaps, avoid flags). Gated by a human.
/// The Ledger stays complete + never-prompted; only APPROVED signals mutate the Brain,
/// almost always as an UPDATE to an existing entry — that's what keeps the Brain lean.
model LearningSignal {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind            String   // "recurring_edit" | "recurring_steer" | "coverage_gap" | "avoid"
  // Loose reference (not a FK): a signal can outlive an entry that gets merged/archived.
  knowledgeItemId String?  // target entry to update; null for a coverage_gap (net-new)
  proposedText    String?  @db.Text // revised canonical answer, new voice rule, or avoid note
  proposedTarget  String   @default("answer") // "answer" | "voice_guide" | "avoid_note" | "new_entry"
  occurrences     Int      @default(1) // how many Ledger events support this
  evidence        Json?    // draft/edit/steer ids + diffs backing the proposal
  status          String   @default("open") // "open" | "approved" | "dismissed"
  category        String?  // inquiry category — routes the training question to a specialist
  assigneeId      String?  // user this training question is assigned to (loose ref, like knowledgeItemId)
  createdAt       DateTime @default(now())
  resolvedAt      DateTime?

  @@index([tenantId, status])
  @@index([tenantId, kind])
  @@index([tenantId, assigneeId, status])
  @@schema("concierge")
}

/// A person, merged across channels by email or handle.
model Customer {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email       String?
  handle      String?
  displayName String?
  // --- purchase-channel facts (rep-maintained; things the data feeds can't see) ---
  purchaseChannel String? // "direct" | "retail" | "dealer"
  channelName     String? // which retailer or dealer sold to them
  // --- AI customer read (cached; regenerated when the basis counts change) ---
  insight      String?   @db.Text
  insightAt    DateTime?
  insightBasis Json?     // counts snapshot the cached insight was computed from
  createdAt   DateTime @default(now())

  tickets Ticket[]

  @@unique([tenantId, email])
  @@index([tenantId, handle])
  @@schema("concierge")
}

/// The core object: a conversation and its state.
model Ticket {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  channel       String   // provider the ticket arrived on
  channelId     String?  // WHICH mailbox (hello@ vs wholesale@) — replies go from here
  channelRef    Channel? @relation(fields: [channelId], references: [id])
  subject       String?
  status        String   @default("new") // new|drafted|in_review|customer_replied|replied|resolved|archived
  // Volley analytics — how many exchanges a ticket took (goal: fewer). Kept in
  // sync from the thread on each intake pass (idempotent recompute, no drift).
  customerReplyCount Int   @default(0) // customer replies = inbound messages after the first
  repReplyCount      Int   @default(0) // our replies = outbound messages
  // return/exchange lifecycle (null = no return in play). Phase A sets
  // "requested"; later phases advance: approved|label_sent|package_received|refunded|exchanged
  returnStatus  String?
  priority      String   @default("normal") // urgent|high|medium|normal (src/lib/priority.ts; rep-editable)
  category      String?  // fine-grained inquiry category (see INQUIRY_CATEGORIES) — drives routing + brain training
  assigneeId    String?
  assignee      User?    @relation("Assignee", fields: [assigneeId], references: [id])
  tags          String[]
  folder        String?
  providerThreadId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages  Message[]
  drafts    Draft[]
  questions TicketQuestion[]

  @@unique([tenantId, providerThreadId])
  @@index([tenantId, status])
  @@index([tenantId, assigneeId])
  @@index([tenantId, category])
  @@index([customerId]) // profile + insight-basis counts
  @@index([tenantId, createdAt(sort: Desc)]) // inbox ordering
  @@schema("concierge")
}

/// A single inbound or outbound message on a ticket.
model Message {
  id                String   @id @default(cuid())
  tenantId          String
  ticketId          String
  ticket            Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  providerMessageId String
  direction         String   // "inbound" | "outbound"
  fromEmail         String?
  fromHandle        String?
  subject           String?
  text              String   @db.Text
  html              String?  @db.Text
  /// [{filename, mimeType, size, attachmentId}] — metadata only; bytes are
  /// streamed on demand from the mailbox (Gmail stays the source of truth).
  attachments       Json?
  sentAt            DateTime

  @@unique([tenantId, providerMessageId])
  @@index([ticketId, sentAt]) // thread ordering
  @@schema("concierge")
}

/// Internal Q&A on a ticket — the Simple View's core object. A CS rep asks a
/// teammate a targeted question ("who can help with the American flag
/// graphic?"); the teammate answers from the stripped-down Q&A view without
/// ever seeing drafts, Brain training, or the full workspace. Never
/// customer-facing; the CS rep folds the answer into the reply themselves.
model TicketQuestion {
  id         String   @id @default(cuid())
  tenantId   String
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  askedById  String
  askedBy    User     @relation("QuestionAskedBy", fields: [askedById], references: [id])
  assigneeId String? // who should answer; null = anyone on the team
  assignee   User?    @relation("QuestionAssignee", fields: [assigneeId], references: [id])
  body       String   @db.Text
  status     String   @default("open") // open | answered (someone replied) | closed (asker got what they needed)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  replies TicketQuestionReply[]

  @@index([tenantId, assigneeId, status]) // the "waiting on you" queue
  @@index([tenantId, status])
  @@index([ticketId])
  @@schema("concierge")
}

/// One message in a question's internal discussion thread.
model TicketQuestionReply {
  id         String         @id @default(cuid())
  tenantId   String
  questionId String
  question   TicketQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  authorId   String
  author     User           @relation("QuestionReplyAuthor", fields: [authorId], references: [id])
  body       String         @db.Text
  createdAt  DateTime       @default(now())

  @@index([questionId, createdAt])
  @@schema("concierge")
}

/// A prepared reply: its cited knowledge, coverage score, and the rep's edits.
model Draft {
  id           String   @id @default(cuid())
  tenantId     String
  ticketId     String
  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  body         String   @db.Text // AI-generated draft
  editedBody   String?  @db.Text // rep's inline-edited version, if any
  coverage     String   // "full" | "partial" | "none"
  coverageNote String?  @db.Text // what to verify (partial), or gap (none)
  policyFlags  String[] // steer asks the knowledge didn't support (needs human decision)
  steerNotes   String?  @db.Text // rep's guidance for this regeneration (chips + freeform)
  regenOf      String?  // prior Draft id this was regenerated from (steer lineage)
  status       String   @default("prepared") // prepared|edited|regenerated|pending_review|approved|sent|discarded
  reviewNote   String?  @db.Text // manager's note when a draft is returned for changes
  sentMessageId String? // provider id once a rep confirms + sends
  createdAt    DateTime @default(now())

  citations DraftCitation[]

  @@index([ticketId])
  @@index([tenantId, status]) // analytics sent-unedited KPI
  @@schema("concierge")
}

/// Which KnowledgeItems grounded a draft (the citations shown to the rep).
model DraftCitation {
  id              String        @id @default(cuid())
  draftId         String
  draft           Draft         @relation(fields: [draftId], references: [id], onDelete: Cascade)
  knowledgeItemId String
  knowledgeItem   KnowledgeItem @relation(fields: [knowledgeItemId], references: [id])
  score           Float // retrieval similarity

  @@index([draftId])
  @@schema("concierge")
}

/// Conditions + actions for organization and routing (the rules engine).
model Rule {
  id         String  @id @default(cuid())
  tenantId   String
  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  priority   Int     @default(100) // run order
  conditions Json    // channel, keywords/intent, VIP, product, sentiment, hours
  actions    Json    // assign, tag, folder, priority, SLA, template, archive, escalate
  active     Boolean @default(true)

  @@index([tenantId, priority])
  @@schema("concierge")
}

/// Agents and admins, per tenant, tied to the platform RBAC model.
model User {
  id               String    @id @default(cuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email            String
  name             String?
  role             String    @default("agent") // agent|team_lead|brand_admin|super_admin
  // financial visibility: revenue/sales summaries render only for flagged
  // users (owners) — being an admin is NOT enough (reps run support as
  // brand_admin without seeing the business's numbers)
  canViewSales     Boolean   @default(false)
  specialties      String[]  // inquiry categories this user handles — drives auto-assign suggestions
  // "simple" lands this user on the Ticket Q&A view with minimal nav — for
  // teammates who only answer internal questions (onboarding mode). Either
  // user can still switch views; this is the default, not a permission.
  preferredView    String    @default("full") // full|simple
  magicLinkToken   String? // sha256 hash of the current magic-link/one-time token
  magicLinkExpires DateTime?
  passwordHash     String? // PBKDF2 (pbkdf2$iter$salt$hash); null = magic-link only
  lastLogin        DateTime?
  createdAt        DateTime  @default(now())

  assignedTickets   Ticket[]              @relation("Assignee")
  questionsAsked    TicketQuestion[]      @relation("QuestionAskedBy")
  questionsAssigned TicketQuestion[]      @relation("QuestionAssignee")
  questionReplies   TicketQuestionReply[] @relation("QuestionReplyAuthor")

  @@unique([tenantId, email])
  @@index([email]) // cross-tenant lookups (magic-link grant, brand switcher)
  @@index([magicLinkToken])
  @@schema("concierge")
}

/// One historical support inquiry (mined from HubSpot for analytics — the
/// 365-day view predates Concierge tickets). Classified once at backfill.
model AnalyticsInquiry {
  id                String   @id @default(cuid())
  tenantId          String
  source            String   // "hubspot"
  threadId          String   @unique
  fromEmail         String?
  subject           String?
  category          String   // warranty | replacement_parts | shipping_order_status | ...
  endSentiment      String   // positive | neutral | negative | unresolved
  threadCreatedAt   DateTime
  daysSincePurchase Int? // inquiry date minus customer's most recent prior order
  // Product mentions extracted from the inquiry text (null = none detected)
  productFamily     String? // silhouette: "Eddies", "Bimini", …
  frameColor        String?
  lensColor         String?
  productStyle      String? // "wrap" | "lifestyle" (from the family's attributes)
  productGender     String? // "unisex" | … (from the family's attributes)

  @@index([tenantId, threadCreatedAt])
  @@index([tenantId, category])
  @@index([tenantId, productFamily])
  @@index([fromEmail])
  @@schema("concierge")
}

/// The product-attribute master: one row per silhouette with its option space.
/// Populated by import-products from HubSpot + Shopify; read by the extractor.
model ProductFamily {
  id          String   @id @default(cuid())
  name        String   @unique // "Eddies", "Bimini XL", …
  frameColors String[]
  lensColors  String[]
  style       String? // "wrap" | "lifestyle"
  gender      String? // "unisex" | null when unspecified
  isSunglasses Boolean @default(true)
  updatedAt   DateTime @updatedAt

  @@schema("concierge")
}

/// A customer's order — one row per order across every configured sales
/// source (Shopify D2C, HubSpot B2B deals, later Stingray's dealer feed).
model CustomerOrder {
  id          String   @id @default(cuid())
  tenantId    String?  // null = legacy Rheos rows (backfilled); importers stamp it
  email       String
  orderedAt   DateTime
  totalAmount Decimal  @db.Decimal(12, 2)
  orderRef    String
  source      String   // "shopify-live" | "hubspot-b2b" | "dealers-circle" | ...
  refunded    Boolean  @default(false) // refunded or partially refunded
  description String?  // human line for non-commerce orders (e.g. a registered boat: model, hull, dealer)
  // --- buyer + ship-to identity (Shopify import) — powers related-customer
  // matching: family members / alternate emails via shared name or address ---
  buyerName    String? // Shopify customer first+last (the account holder)
  shipName     String? // shipping_address.name (recipient — differs on gifts)
  shipAddress1 String?
  shipCity     String?
  shipState    String? // province_code
  shipZip      String?

  @@unique([source, orderRef])
  @@index([email])
  @@index([tenantId, source]) // sources panel groupBy over ~80k rows
  @@index([shipZip]) // related-customer address matching
  @@schema("concierge")
}

/// A tenant's configured sales-data intake (the admin-visible half — secrets
/// stay in env). Rheos: Shopify D2C + HubSpot B2B deals. Stingray: Dealers
/// Circle / ERP, pending their data definition.
model SalesSource {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key         String    // matches CustomerOrder.source: "shopify-live", "hubspot-b2b", ...
  label       String
  kind        String    // "shopify" | "hubspot_deals" | "erp" | "manual"
  channelType String    // "d2c" | "b2b"
  notes       String?   @db.Text
  active      Boolean   @default(false)
  lastSyncAt  DateTime?
  lastCount   Int?      // rows touched on the last sync
  createdAt   DateTime  @default(now())

  @@unique([tenantId, key])
  @@schema("concierge")
}

/// Replacement temple-arm stock, keyed by SKU. Left and right are counted
/// separately because one side runs out first (the arm report has a 30-left /
/// 1-right SKU). Hand-maintained on the Parts & Replacements page and surfaced
/// into warranty / replacement_parts drafts so a rep sees stock without leaving
/// the ticket. Rheos-only in practice; tenant-scoped like everything else.
model ArmInventory {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sku        String
  brand      String // frame model family, e.g. "Bahias", "Eddies", "Coopers"
  container  Int? // physical storage container from the arm report
  leftCount  Int      @default(0)
  rightCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, sku])
  @@index([tenantId, brand])
  @@schema("concierge")
}

/// One wholesale line item from a won HubSpot deal — which retail account
/// bought which product, when, and where. Powers "which store near the
/// customer carries X" for reps (Ask the Brain) and draft grounding.
model StockistSale {
  id            String   @id @default(cuid())
  tenantId      String
  dealId        String
  companyName   String
  city          String?
  state         String?
  zip           String?
  itemName      String
  sku           String?
  productFamily String?  // normalized silhouette via the product extractor
  quantity      Int      @default(1)
  closedAt      DateTime

  @@unique([dealId, itemName])
  @@index([tenantId, productFamily, closedAt])
  @@index([tenantId, state])
  @@schema("concierge")
}

/// Monthly sales aggregates for the inquiries-vs-sales chart, per source
/// (shopify-live, amazon) — the chart sums sources per month.
model SalesMonthly {
  month   DateTime
  source  String
  orders  Int
  revenue Decimal  @db.Decimal(14, 2)

  @@id([month, source])
  @@schema("concierge")
}

/// A pinned context note — a fact reps want teammates and drafts to know,
/// scoped to ONE ticket (this conversation only) or to the customer (all
/// their tickets). Optional expiration: an expired note stops feeding drafts
/// immediately and queues on the admin dashboard for review — extend it,
/// make it permanent, or remove it, so stale facts never linger.
model ContextNote {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId String?   // customer scope — exactly one of customer/ticket/product is set
  ticketId   String?   // ticket scope
  productFamily String? // product scope — grounds every ticket mentioning this family
  body       String    @db.Text
  expiresAt  DateTime?
  createdBy  String?   // user id (loose ref — notes outlive team changes)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([tenantId, customerId])
  @@index([tenantId, ticketId])
  @@index([tenantId, productFamily])
  @@index([tenantId, expiresAt])
  @@schema("concierge")
}

/// Who did what and when (drafts, edits, sends, promotions, rule actions).
model AuditEvent {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorId   String?
  action    String   // draft_generated|draft_edited|reply_sent|answer_promoted|rule_fired|...
  entity    String   // "ticket:<id>", "knowledge:<id>"
  meta      Json?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, action]) // detect-learning scans draft_edited
  @@schema("concierge")
}
