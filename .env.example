# Concierge environment — copy to .env and fill in. Every value here is a
# placeholder; real credentials live only in .env (gitignored) and on the
# server (/opt/concierge/.env, backed up nightly per docs/BACKUP-RECOVERY.md).

# --- database (Supabase; concierge schema) ---
# App runtime = SESSION pooler :5432 (see CLAUDE.md for the pool budget).
DATABASE_URL="postgresql://user:password@aws-0-us-west-2.pooler.supabase.com:5432/postgres?schema=concierge&connection_limit=6&pool_timeout=20"
DIRECT_URL="postgresql://user:password@aws-0-us-west-2.pooler.supabase.com:5432/postgres?schema=concierge"

# --- auth ---
AUTH_SECRET="generate: openssl rand -base64 32"
AUTH_URL="https://concierge.scribechs.com"   # REQUIRED in prod (proxy origin fix)
AUTH_ALLOWLIST="you@example.com"             # bootstrap only; User rows are the real grant
NEXT_PUBLIC_APP_URL="https://concierge.scribechs.com"

# --- AI ---
ANTHROPIC_API_KEY=""
VOYAGE_API_KEY=""                            # embeddings (semantic retrieval)

# --- email (Mailgun: magic links, digests) ---
MAILGUN_API_KEY=""
MAILGUN_DOMAIN="justforfun.scribechs.com"
EMAIL_FROM="Concierge <no-reply@justforfun.scribechs.com>"
DIGEST_RECIPIENTS="jake@scribechs.com"       # comma-separated

# --- Gmail intake/send (service account w/ domain-wide delegation) ---
RHEOS_GMAIL_CLIENT_EMAIL=""
RHEOS_GMAIL_PRIVATE_KEY=""
CONCIERGE_LIVE_SEND="false"                  # true = replies actually transmit

# --- integrations ---
HUBSPOT_TOKEN=""
SHIPSTATION_API_KEY=""
SHIPSTATION_API_SECRET=""
SHOPIFY_SHOP=""
SHOPIFY_CLIENT_ID=""
SHOPIFY_CLIENT_SECRET=""
SHOPIFY_API_VERSION="2026-01"

# --- Stingray (Graph adapter, pending their IT) ---
STINGRAY_GRAPH_TENANT_ID=""
STINGRAY_GRAPH_CLIENT_ID=""
STINGRAY_GRAPH_CLIENT_SECRET=""

# Magic-link sign-in is OFF by default (password-only). Set to "true" to
# re-enable the emailed-link flow (route + verify provider + login page UI).
# NEXT_PUBLIC_MAGIC_LINK=true
