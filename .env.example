# Concierge — environment. Copy to .env and fill. Never commit real secrets.

# Shared birdseye Postgres; Concierge lives in its own `concierge` schema.
DATABASE_URL="postgresql://USER:PASS@HOST:5432/DB?schema=concierge"

# Anthropic (classification + drafting). Model id is centralized in src/lib/anthropic.ts.
ANTHROPIC_API_KEY=""

# Voyage AI — Brand Brain embeddings (1024-dim, voyage-3-large).
VOYAGE_API_KEY=""

# --- Rheos tenant: Gmail (Google Workspace, hello@rheosgear.com) ---
# Service account with domain-wide delegation, impersonating the shared mailbox.
RHEOS_GMAIL_CLIENT_EMAIL=""
RHEOS_GMAIL_PRIVATE_KEY=""
RHEOS_GMAIL_PUBSUB_TOPIC=""   # projects/<proj>/topics/<topic> for push intake

# --- Stingray tenant: Microsoft 365 (Graph, support@stingrayboats.com) ---
# Azure app registration; filled when Stingray onboards (adapter already scaffolded).
STINGRAY_GRAPH_TENANT_ID=""
STINGRAY_GRAPH_CLIENT_ID=""
STINGRAY_GRAPH_CLIENT_SECRET=""

# --- Seed source: HubSpot (mine hello@ tickets into FAQ candidates) ---
HUBSPOT_TOKEN=""

# Auth
NEXTAUTH_SECRET=""
NEXTAUTH_URL="https://concierge.scribechs.com"
