{
  "name": "concierge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 3014",
    "build": "next build",
    "start": "next start -p 3014",
    "lint": "eslint src tests",
    "db:setup": "node scripts/db-setup.cjs",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-inquiries": "tsx prisma/seed-inquiries.ts",
    "db:mine-hubspot": "tsx prisma/mine-hubspot.ts",
    "db:studio": "prisma studio",
    "db:intake-gmail": "tsx prisma/intake-gmail.ts",
    "db:import-products": "tsx prisma/import-products.ts",
    "db:detect-learning": "tsx prisma/detect-learning.ts",
    "db:embed": "tsx prisma/embed-knowledge.ts",
    "db:analytics-backfill": "tsx prisma/analytics-backfill.ts",
    "db:import-shopify-orders": "tsx prisma/import-shopify-orders.ts",
    "db:mine-playbooks": "tsx prisma/mine-reply-playbooks.ts",
    "db:enrich-inquiries": "tsx prisma/enrich-inquiries.ts",
    "db:seed-users": "tsx prisma/seed-users.ts",
    "db:backfill-categories": "tsx prisma/backfill-ticket-categories.ts",
    "db:import-hubspot-orders": "tsx prisma/import-hubspot-orders.ts",
    "db:seed-sales-sources": "tsx prisma/seed-sales-sources.ts",
    "send-digest": "tsx prisma/send-digest.ts",
    "db:detect-handled": "tsx prisma/detect-handled.ts",
    "db:migrate:new": "prisma migrate diff --from-schema-datasource prisma/schema.prisma --to-schema-datamodel prisma/schema.prisma --script",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:push:UNSAFE": "echo 'db push is banned against the shared DB (DEVELOPMENT-STANDARDS \u00a74). Author a migration: npm run db:migrate:new > prisma/migrations/<ts>_<name>/migration.sql, review it, then db:migrate:deploy.' && exit 1",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "predeploy-check": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@prisma/client": "^6.19.2",
    "googleapis": "^144.0.0",
    "next": "^16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "pino": "^10.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "pg": "^8.13.1",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.8",
    "prisma": "^6.19.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.10"
  }
}
